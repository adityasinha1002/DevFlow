{
  "name": "devflow",
  "displayName": "DevFlow",
  "description": "DevFlow — an autonomous AI developer agent for VS Code powered by Gemini.",
  "version": "1.0.0",
  "publisher": "adityasinha",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:devflow.start"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "devflow.start",
        "title": "Start DevFlow AI Agent"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build": "npm run compile"
  },
  "dependencies": {
    "@google/genai": "latest",
    "@modelcontextprotocol/sdk": "latest",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.4.0"
  }
}